# ───────────────────────────────────────────────────────────────────
# vnpy_strategy_dev 部署环境配置示例
# ───────────────────────────────────────────────────────────────────
#
# 用法 (P0-1 + P0-2 凭证 / 路径外置):
#   1. 拷贝本文件为 .env.production (或 .env.staging / .env.local)
#   2. 填实际值 (敏感值 + 部署机路径)
#   3. .env.production 在 .gitignore 不会被提交
#   4. run_ml_headless.py 启动期 load_dotenv() 自动加载, 优先级:
#         .env.production > .env > 系统 env > 代码内默认
#
# 切换环境: 设 env DOTENV_FILE=.env.staging 即用 staging 配置.
# ───────────────────────────────────────────────────────────────────


# ═══════════════════════════════════════════════════════════════════
# 凭证 (敏感, 不可 commit)
# ═══════════════════════════════════════════════════════════════════

# tushare token (从 https://tushare.pro 注册获取)
TUSHARE_TOKEN=

# miniqmt 实盘账户 (实盘 / V3 仿真账户都用此)
# - 资金账号 由券商提供 (e.g. 1300012345 / 招商证券 8 位)
# - 客户端路径 = 迅投极速终端 userdata_mini 目录绝对路径
QMT_ACCOUNT=
QMT_CLIENT_PATH=E:/迅投极速交易终端 睿智融科版/userdata_mini


# ═══════════════════════════════════════════════════════════════════
# 数据根目录
# ═══════════════════════════════════════════════════════════════════

# vnpy_data 根: qlib_data_bin / snapshots / state / models 都在此下
QS_DATA_ROOT=D:/vnpy_data

# 策略每日产物: predictions/selections/diagnostics/metrics
ML_OUTPUT_ROOT=D:/ml_output

# bundle 部署目录: 训练机 rsync 过来的子目录命名 = mlflow run_id (32 hex)
VNPY_MODEL_ROOT=D:/vnpy_data/models


# ═══════════════════════════════════════════════════════════════════
# 推理子进程
# ═══════════════════════════════════════════════════════════════════

# qlib + lightgbm + mlflow + sklearn 的 Python 解释器 (不是 vnpy 主 python)
INFERENCE_PYTHON=E:/ssd_backup/Pycharm_project/python-3.11.0-amd64/python.exe


# ═══════════════════════════════════════════════════════════════════
# 数据管道开关
# ═══════════════════════════════════════════════════════════════════

# 设 1 启用 vnpy_tushare_pro 20:00 cron 拉数据 + filter snapshot + qlib bin dump.
# 实盘必须为 1, 否则 21:00 推理找不到当日 filter snapshot 直接 raise.
ML_DAILY_INGEST_ENABLED=1


# ═══════════════════════════════════════════════════════════════════
# 策略 / Gateway 配置文件 (YAML)
# ═══════════════════════════════════════════════════════════════════

# 策略 + Gateway 列表 YAML 路径.
# .yaml 中 ${VAR} 占位符会被本 .env 中的值替换.
STRATEGIES_CONFIG=config/strategies.production.yaml


# ═══════════════════════════════════════════════════════════════════
# 高级 / 可选
# ═══════════════════════════════════════════════════════════════════

# 多策略 trigger_time 冲突时 escape (设 1 跳过校验, 仅在内存 ≥ N×5GB 时使用)
# ALLOW_TRIGGER_TIME_COLLISION=

# 推理 ic 回填 service 扫描天数 (默认 30)
# IC_BACKFILL_SCAN_DAYS=30
