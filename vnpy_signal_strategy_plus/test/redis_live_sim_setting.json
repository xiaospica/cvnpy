{
    "_doc": "近实盘链路测试配置：聚宽 -> Redis stream(etf_rotation_basic) -> redis_to_mysql_bridge -> MySQL trade_signal_events -> RedisLiveSimTestStrategy -> QMT_SIM。该配置不允许使用 position.csv 持仓引导，模拟柜台应从 1000000 纯现金开始。",

    "strategy_class": "RedisLiveSimTestStrategy",
    "strategy_name": "etf_rotation_basic",
    "initial_capital": 1000000.0,

    "redis": {
        "_doc": "仅用于链路校验和人工核对；实际 Redis 消费由 scripts/redis_bridge_setting.local.json 控制。",
        "host": "106.54.63.204",
        "port": 6888,
        "password": "REPLACE_ME",
        "db": 0,
        "stream_key": "etf_rotation_basic"
    },

    "strategy": {
        "poll_interval": 0.05,
        "start_date": "20190101 00:00:00",
        "end_date": "20300101 00:00:00"
    },

    "replay": {
        "_doc": "sim_replay 会按 trade_signal_events.remark 的历史时间顺序推进模拟柜台，适合聚宽回测写历史交易日信号；live 会退回实时当天轮询，便于未来切换实盘网关。",
        "mode": "sim_replay",
        "consume_historical_remarks": true,
        "idle_settle_seconds": 30
    },

    "mysql": {
        "host": "106.54.63.204",
        "port": 3306,
        "user": "root",
        "password": "REPLACE_ME",
        "db": "mysql",
        "purge_before_replay": true
    },

    "sim": {
        "_doc": "近实盘测试使用 QMT_SIM。切实盘时，应使用同一策略语义但由实盘启动入口加载真实网关。",
        "account_id": "QMT_SIM",
        "gateway_name": "QMT_SIM",
        "db_dir": "D:/vnpy_data/state",
        "delete_db_before_replay": false,
        "connect_setting": {
            "模拟资金": 1000000.0,
            "行情源": "merged_parquet",
            "merged_parquet_merged_root": "D:/vnpy_data/snapshots/merged",
            "merged_parquet_reference_kind": "today_open",
            "merged_parquet_fallback_days": 10,
            "启用持久化": "是",
            "持久化目录": "D:/vnpy_data/state"
        }
    },

    "webtrader": {
        "_doc": "近实盘测试默认使用生产 WebTrader 端口，mlearnweb 前端才能直接看到该策略卡片。启动前请确认没有另一个 webtrader 正占用 2014/4102/8001。",
        "enable": true,
        "rep_address": "tcp://127.0.0.1:2014",
        "pub_address": "tcp://127.0.0.1:4102",
        "http_host": "127.0.0.1",
        "http_port": "8001",
        "node_id": "redis-live-sim"
    },

    "wait": {
        "max_seconds": 120,
        "poll_interval": 2
    }
}
