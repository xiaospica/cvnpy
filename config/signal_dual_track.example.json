{
    "_doc": "SignalStrategyPlus dual-track runtime config template. Copy this file to <VNPY_DATA_ROOT>/config/signal_dual_track.json or set SIGNAL_DUAL_TRACK_CONFIG to an absolute path.",
    "strategy_class": "RedisLiveSimTestStrategy",
    "strategy_name": "harvester_micro_cap_1",
    "initial_capital": 1000000.0,

    "redis": {
        "_doc": "Redis is used by the JoinQuant-to-MySQL bridge. The runner itself reads MySQL v2 trade_signal_events.",
        "host": "127.0.0.1",
        "port": 6379,
        "password": "REPLACE_ME",
        "db": 0,
        "stream_key": "harvester_micro_cap_1"
    },

    "strategy": {
        "poll_interval": 0.05,
        "start_date": "20190101 00:00:00",
        "end_date": "20300101 00:00:00"
    },

    "replay": {
        "_doc": "sim_replay replays historical MySQL v2 signal remarks through QMT_SIM/FakeQMT. live only polls current/live signals and is used by the v3 real-source leg.",
        "mode": "sim_replay",
        "consume_historical_remarks": true,
        "idle_settle_seconds": 30
    },

    "mysql": {
        "host": "127.0.0.1",
        "port": 3306,
        "user": "root",
        "password": "REPLACE_ME",
        "db": "mysql",
        "purge_before_replay": true
    },

    "sim": {
        "_doc": "Simulation gateways persist under <VNPY_DATA_ROOT>/state and always start from pure cash after explicit cleanup.",
        "account_id": "QMT_SIM",
        "gateway_name": "QMT_SIM",
        "db_dir": "%VNPY_DATA_ROOT%/state",
        "delete_db_before_replay": false,
        "connect_setting": {
            "模拟资金": 1000000.0,
            "行情源": "merged_parquet",
            "merged_parquet_merged_root": "%VNPY_DATA_ROOT%/snapshots/merged",
            "merged_parquet_reference_kind": "today_open",
            "merged_parquet_fallback_days": 10,
            "启用持久化": "是",
            "持久化目录": "%VNPY_DATA_ROOT%/state"
        }
    },

    "webtrader": {
        "enable": true,
        "rep_address": "tcp://127.0.0.1:2014",
        "pub_address": "tcp://127.0.0.1:4102",
        "http_host": "127.0.0.1",
        "http_port": "8001",
        "node_id": "signal-dual-track"
    },

    "wait": {
        "max_seconds": 120,
        "poll_interval": 2
    }
}
